# Copy and edit before running setup:
#   cp jenkins/setup.env.example jenkins/setup.env
#
# Run full setup from repo root:
#   ./scripts/setup-jenkins-full.sh

# ── AWS (required) ───────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=440977419877
ECR_REGISTRY=440977419877.dkr.ecr.ap-south-1.amazonaws.com

# ── Git (required) ─────────────────────────────────────────────────────────────
GIT_REPO_URL=https://github.com/CODEX-CRAFTSMAN-LABS/enterprise-rag.git
DEV_BRANCH=develop
PROD_BRANCH=main

# ── App EC2 deploy target (required for deploy stages) ───────────────────────
# Set after app host exists, or leave empty until app EC2 is provisioned.
STAGING_SSH_HOST=
STAGING_SSH_USER=ubuntu
STAGING_PATH=/opt/enterprise-rag

# Private key Jenkins uses to SSH into the app EC2 (no spaces in path).
STAGING_SSH_KEY_PATH=${HOME}/.ssh/enterprise-rag-v2.pem

# ── Deploy behaviour ─────────────────────────────────────────────────────────
DEPLOY_TARGET=ec2
ENABLE_DEPLOY=true
ENABLE_SONAR=false
OLLAMA_IMAGE=alpine/ollama:0.23.2

# ── Jenkins EC2 provisioning (optional — skip if hosts already exist) ────────
SKIP_PROVISION=false
PROVISION_JENKINS=true
PROVISION_APP=true

# Required when PROVISION_JENKINS=true or PROVISION_APP=true:
AMI_ID=
SUBNET_ID=
JENKINS_SECURITY_GROUP_ID=
APP_SECURITY_GROUP_ID=
KEY_NAME=enterprise-rag-v2

# IAM instance profile names (attach roles with ECR push/pull policies first)
JENKINS_IAM_INSTANCE_PROFILE=
APP_IAM_INSTANCE_PROFILE=

JENKINS_INSTANCE_TYPE=t3.small
APP_INSTANCE_TYPE=t3.xlarge
JENKINS_INSTANCE_NAME=enterprise-rag-jenkins
APP_INSTANCE_NAME=enterprise-rag-app

# Set when SKIP_PROVISION=true and Jenkins already runs:
JENKINS_SSH_HOST=
JENKINS_SSH_USER=ubuntu
JENKINS_SSH_KEY_PATH=${HOME}/.ssh/enterprise-rag-v2.pem

# ── Jenkins finalize (run on Jenkins host after bootstrap) ─────────────────────
JENKINS_URL=http://127.0.0.1:8080
# After first UI login, create an API token and set JENKINS_USER + JENKINS_TOKEN
JENKINS_USER=admin
JENKINS_TOKEN=
# Or use initial admin password once (token preferred):
JENKINS_PASSWORD=

# Auto-run seed job after configure (requires JENKINS_TOKEN or JENKINS_PASSWORD)
RUN_SEED_JOB=true
