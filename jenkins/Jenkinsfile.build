// Build + test + push one service image to ECR (no deploy).
// SERVICE is inferred from job name (build/ingestion-service | build/query-service).
// Override AWS_* via Jenkins global env if needed. Parameter: GIT_COMMIT_SHA (40 chars).

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timestamps()
        timeout(time: 40, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        JAVA_HOME = tool name: 'jdk-17', type: 'jdk'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"
        GRADLE_OPTS = '-Dorg.gradle.daemon=false'
        ENABLE_SONAR = "${env.ENABLE_SONAR ?: 'false'}"
        AWS_REGION = "${env.AWS_REGION ?: 'ap-south-1'}"
        AWS_ACCOUNT_ID = "${env.AWS_ACCOUNT_ID ?: '440977419877'}"
        ECR_REGISTRY = "${env.ECR_REGISTRY ?: ''}"
        GIT_REPO_URL = "${env.GIT_REPO_URL ?: 'https://github.com/CODEX-CRAFTSMAN-LABS/enterprise-rag.git'}"
        GIT_CREDENTIALS_ID = "${env.GIT_CREDENTIALS_ID ?: ''}"
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    def jobName = env.JOB_NAME ?: ''
                    if (jobName.contains('ingestion')) {
                        env.SERVICE = 'ingestion'
                    } else if (jobName.contains('query')) {
                        env.SERVICE = 'query'
                    }
                    if (!env.SERVICE?.trim() || !(env.SERVICE in ['ingestion', 'query'])) {
                        error("Cannot infer SERVICE from job name: ${jobName}")
                    }

                    def commitSha = params.GIT_COMMIT_SHA?.trim()?.toLowerCase()
                    if (!commitSha) {
                        error('Set GIT_COMMIT_SHA (full 40-character Git commit SHA).')
                    }
                    if (!(commitSha ==~ /^[0-9a-f]{40}$/)) {
                        error("GIT_COMMIT_SHA must be a full 40-character commit SHA (got: ${commitSha})")
                    }
                    env.GIT_COMMIT_SHA = commitSha
                    env.GIT_SHA_SHORT = commitSha.take(12)

                    echo "Building ${SERVICE}-service at commit ${commitSha}"

                    def extensions = [
                        [$class: 'CloneOption', noTags: false, shallow: false, depth: 0, timeout: 20]
                    ]
                    def userRemote = [url: env.GIT_REPO_URL]
                    if (env.GIT_CREDENTIALS_ID?.trim()) {
                        userRemote.credentialsId = env.GIT_CREDENTIALS_ID.trim()
                    }
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: commitSha]],
                        extensions: extensions,
                        userRemoteConfigs: [userRemote]
                    ])

                    def checkedOutSha = sh(returnStdout: true, script: 'git rev-parse HEAD').trim()
                    if (checkedOutSha != commitSha) {
                        error("Checkout mismatch: expected ${commitSha}, got ${checkedOutSha}")
                    }
                }
                sh '''
                    chmod +x gradlew
                    if [ -d scripts ]; then
                      chmod +x scripts/*.sh
                    fi
                '''
            }
        }

        stage('Build & Test') {
            steps {
                script {
                    def gradleModule = env.SERVICE == 'ingestion' ? ':ingestion-service' : ':query-service'
                    env.GRADLE_MODULE = gradleModule
                    env.JUNIT_PATTERN = "${gradleModule.replace(':', '')}/build/test-results/test/*.xml"
                }
                sh './gradlew :rag-common:build ${GRADLE_MODULE}:clean ${GRADLE_MODULE}:build --no-daemon'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '${JUNIT_PATTERN}'
                }
            }
        }

        stage('SonarQube') {
            when { expression { env.ENABLE_SONAR == 'true' } }
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        if command -v sonar-scanner >/dev/null 2>&1; then
                          sonar-scanner -Dproject.settings=sonar-project.properties \
                            -Dsonar.branch.name="${GIT_COMMIT_SHA}"
                        else
                          echo "Skipping Sonar — scanner not installed"
                        fi
                    '''
                }
            }
        }

        stage('Derive Image Metadata') {
            steps {
                script {
                    if (!env.AWS_REGION?.trim()) {
                        error('Set AWS_REGION for ECR operations.')
                    }

                    def registry = env.ECR_REGISTRY?.trim()
                    if (!registry) {
                        if (!env.AWS_ACCOUNT_ID?.trim()) {
                            error('Set AWS_ACCOUNT_ID or ECR_REGISTRY for ECR image publishing.')
                        }
                        registry = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
                    }

                    def ecrRepo = env.SERVICE == 'ingestion'
                        ? 'enterprise-rag-ingestion-service'
                        : 'enterprise-rag-query-service'
                    def commitSha = env.GIT_COMMIT_SHA

                    env.IMAGE_TAG = commitSha
                    env.IMAGE_TAG_SHORT = "sha-${env.GIT_SHA_SHORT}"
                    env.ECR_REGISTRY = registry
                    env.ECR_REPOSITORY = ecrRepo
                    env.SERVICE_IMAGE = "${registry}/${ecrRepo}:${commitSha}"
                    env.SERVICE_IMAGE_SHORT = "${registry}/${ecrRepo}:${env.IMAGE_TAG_SHORT}"
                }
            }
        }

        stage('Ensure ECR Repository') {
            steps {
                sh './scripts/create-ecr-repos.sh'
            }
        }

        stage('Docker Build & Tag') {
            steps {
                script {
                    env.DOCKERFILE = env.SERVICE == 'ingestion'
                        ? 'ingestion-service/Dockerfile'
                        : 'query-service/Dockerfile'
                }
                sh '''
                    docker build --platform linux/amd64 -f "${DOCKERFILE}" -t "${SERVICE_IMAGE}" .
                    docker tag "${SERVICE_IMAGE}" "${SERVICE_IMAGE_SHORT}"
                '''
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                    aws ecr get-login-password --region "${AWS_REGION}" \
                      | docker login --username AWS --password-stdin "${ECR_REGISTRY}"
                    docker push "${SERVICE_IMAGE}"
                    docker push "${SERVICE_IMAGE_SHORT}"
                    echo "Pushed ${SERVICE} image tag: ${IMAGE_TAG}"
                    echo "Deploy with: deploy/<env>/${SERVICE}-service and GIT_COMMIT_SHA=${IMAGE_TAG}"
                '''
            }
        }
    }

    post {
        success { echo "Build OK — ${SERVICE}-service image ${IMAGE_TAG} in ECR" }
        failure { echo "Build failed for ${SERVICE}-service." }
        always { cleanWs(deleteDirs: true) }
    }
}
