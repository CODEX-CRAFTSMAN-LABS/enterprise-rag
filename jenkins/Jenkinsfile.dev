// Jenkins — DEVELOPMENT pipeline
// Job config: Pipeline from SCM → Script Path: jenkins/Jenkinsfile.dev
// Branch: develop | feature/*
//
// Credentials:
//   kubeconfig-dev-id  — kubeconfig file for dev cluster (Secret file)
//   docker-registry    — optional registry push (username/password)

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        JAVA_HOME = tool name: 'jdk-17', type: 'jdk'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"
        GRADLE_OPTS = '-Dorg.gradle.daemon=false'
        COVERAGE_MINIMUM = '0.75'
        ENV_NAME = 'dev'
        K8S_NAMESPACE = 'enterprise-rag-dev'
        K8S_OVERLAY = 'k8s/overlays/dev'
        IMAGE_TAG = "dev-${env.BUILD_NUMBER}"
        ENABLE_SONAR = "${env.ENABLE_SONAR ?: 'true'}"
        ENABLE_CHECKMARX = 'false'
        ENABLE_DEPLOY = "${env.ENABLE_DEPLOY ?: 'true'}"
        DOCKER_REGISTRY = "${env.DOCKER_REGISTRY ?: ''}"
        IMAGE_NAMESPACE = "${env.IMAGE_NAMESPACE ?: 'codex-craftsman-labs'}"
        DEPLOY_TARGET = "${env.DEPLOY_TARGET ?: 'ec2'}"
        STAGING_SSH_HOST = "${env.STAGING_SSH_HOST ?: ''}"
        STAGING_SSH_USER = "${env.STAGING_SSH_USER ?: 'ubuntu'}"
        STAGING_PATH = "${env.STAGING_PATH ?: '/opt/enterprise-rag'}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'chmod +x gradlew scripts/*.sh 2>/dev/null || chmod +x gradlew'
            }
        }

        stage('Build & Test') {
            steps {
                sh './gradlew clean build jacocoAggregatedReport --no-daemon'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/build/test-results/test/*.xml'
                }
            }
        }

        stage('Coverage Gate') {
            steps {
                sh "./gradlew coverageCheck -PcoverageMinimum=${COVERAGE_MINIMUM} --no-daemon"
            }
        }

        stage('SonarQube') {
            when { expression { env.ENABLE_SONAR == 'true' } }
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        if command -v sonar-scanner >/dev/null 2>&1; then
                          sonar-scanner -Dproject.settings=sonar-project.properties \
                            -Dsonar.branch.name=develop
                        else
                          echo "Skipping Sonar — scanner not installed"
                        fi
                    '''
                }
            }
        }

        stage('Docker Build & Tag') {
            steps {
                script {
                    def reg = env.DOCKER_REGISTRY?.trim()
                    def namespace = env.IMAGE_NAMESPACE?.trim()
                    def prefix = reg ? "${reg}/${namespace}" : "enterprise-rag"
                    env.INGESTION_IMAGE = "${prefix}/enterprise-rag-ingestion-service:${IMAGE_TAG}"
                    env.QUERY_IMAGE = "${prefix}/enterprise-rag-query-service:${IMAGE_TAG}"
                    env.INGESTION_IMAGE_LATEST = "${prefix}/enterprise-rag-ingestion-service:staging-latest"
                    env.QUERY_IMAGE_LATEST = "${prefix}/enterprise-rag-query-service:staging-latest"
                }
                sh '''
                    docker build -f ingestion-service/Dockerfile -t ${INGESTION_IMAGE} .
                    docker build -f query-service/Dockerfile -t ${QUERY_IMAGE} .
                    docker tag ${INGESTION_IMAGE} ${INGESTION_IMAGE_LATEST}
                    docker tag ${QUERY_IMAGE} ${QUERY_IMAGE_LATEST}
                '''
            }
        }

        stage('Push Images') {
            when {
                expression { return env.DOCKER_REGISTRY?.trim() }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-registry', usernameVariable: 'DR_USER', passwordVariable: 'DR_PASS')]) {
                    sh '''
                        echo "$DR_PASS" | docker login "$DOCKER_REGISTRY" -u "$DR_USER" --password-stdin
                        docker push ${INGESTION_IMAGE}
                        docker push ${QUERY_IMAGE}
                        docker push ${INGESTION_IMAGE_LATEST}
                        docker push ${QUERY_IMAGE_LATEST}
                    '''
                }
            }
        }

        stage('Deploy to EC2 (Staging)') {
            when {
                expression {
                    env.ENABLE_DEPLOY == 'true' &&
                    env.DEPLOY_TARGET == 'ec2' &&
                    env.STAGING_SSH_HOST?.trim() &&
                    env.DOCKER_REGISTRY?.trim()
                }
            }
            steps {
                withCredentials([
                    sshUserPrivateKey(credentialsId: 'staging-ssh-key', keyFileVariable: 'SSH_KEY'),
                    usernamePassword(credentialsId: 'docker-registry', usernameVariable: 'DR_USER', passwordVariable: 'DR_PASS')
                ]) {
                    sh '''
                        export SSH_KEY_PATH="$SSH_KEY"
                        export REGISTRY_USERNAME="$DR_USER"
                        export REGISTRY_PASSWORD="$DR_PASS"
                        ./scripts/deploy-ec2-compose.sh
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes (Dev)') {
            when {
                expression {
                    env.ENABLE_DEPLOY == 'true' && env.DEPLOY_TARGET == 'k8s'
                }
            }
            steps {
                sh '''
                    kubectl version --client || true
                    if [ -f k8s/overlays/dev/kustomization.yaml ]; then
                      kubectl apply -k ${K8S_OVERLAY}
                      kubectl rollout status deployment/ingestion-service -n ${K8S_NAMESPACE} --timeout=300s || true
                      kubectl rollout status deployment/query-service -n ${K8S_NAMESPACE} --timeout=300s || true
                      kubectl rollout status deployment/prometheus -n ${K8S_NAMESPACE} --timeout=120s || true
                      kubectl rollout status deployment/grafana -n ${K8S_NAMESPACE} --timeout=120s || true
                    fi
                '''
            }
        }
    }

    post {
        success { echo "Dev pipeline OK — namespace ${K8S_NAMESPACE}" }
        failure { echo 'Dev pipeline failed.' }
        always { cleanWs(deleteDirs: true) }
    }
}
