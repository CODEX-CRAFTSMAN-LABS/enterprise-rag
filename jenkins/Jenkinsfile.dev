// Jenkins — DEVELOPMENT pipeline (full build + ECR push + deploy)
// Job config: Pipeline from SCM → Script Path: jenkins/Jenkinsfile.dev
//
// For deploy-only (images already in ECR from GitHub Actions), use:
//   jenkins/Jenkinsfile.deploy-ecr  or job deploy/dev/enterprise-rag-from-ecr
//
// Credentials:
//   staging-ssh-key  — SSH private key for the app EC2 host
//
// Required environment:
//   AWS_REGION
//   AWS_ACCOUNT_ID or ECR_REGISTRY
//   STAGING_SSH_HOST

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        JAVA_HOME = tool name: 'jdk-17', type: 'jdk'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"
        GRADLE_OPTS = '-Dorg.gradle.daemon=false'
        COVERAGE_MINIMUM = '0.75'
        ENV_NAME = 'dev'
        K8S_NAMESPACE = 'enterprise-rag-dev'
        K8S_OVERLAY = 'k8s/overlays/dev'
        ENABLE_SONAR = "${env.ENABLE_SONAR ?: 'true'}"
        ENABLE_CHECKMARX = 'false'
        ENABLE_DEPLOY = "${env.ENABLE_DEPLOY ?: 'true'}"
        DEPLOY_TARGET = "${env.DEPLOY_TARGET ?: 'ec2'}"
        AWS_REGION = "${env.AWS_REGION ?: ''}"
        AWS_ACCOUNT_ID = "${env.AWS_ACCOUNT_ID ?: ''}"
        ECR_REGISTRY = "${env.ECR_REGISTRY ?: ''}"
        STAGING_SSH_HOST = "${env.STAGING_SSH_HOST ?: ''}"
        STAGING_SSH_USER = "${env.STAGING_SSH_USER ?: 'ubuntu'}"
        STAGING_PATH = "${env.STAGING_PATH ?: '/opt/enterprise-rag'}"
        OLLAMA_IMAGE = "${env.OLLAMA_IMAGE ?: 'alpine/ollama:0.23.2'}"
        GIT_REPO_URL = "${env.GIT_REPO_URL ?: 'https://github.com/CODEX-CRAFTSMAN-LABS/enterprise-rag.git'}"
        GIT_CREDENTIALS_ID = "${env.GIT_CREDENTIALS_ID ?: ''}"
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    def branch = params.GIT_BRANCH?.trim()
                    if (!branch) {
                        error('Set GIT_BRANCH parameter (branch name to build).')
                    }
                    env.BRANCH_NAME = branch

                    def gitArgs = [
                        branch: branch,
                        url: env.GIT_REPO_URL
                    ]
                    if (env.GIT_CREDENTIALS_ID?.trim()) {
                        gitArgs.credentialsId = env.GIT_CREDENTIALS_ID.trim()
                    }
                    git(gitArgs)
                }
                sh '''
                    chmod +x gradlew
                    if [ -d scripts ]; then
                      chmod +x scripts/*.sh
                    fi
                '''
            }
        }

        stage('Build & Test') {
            steps {
                sh './gradlew clean build jacocoAggregatedReport --no-daemon'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/build/test-results/test/*.xml'
                }
            }
        }

        stage('Coverage Gate') {
            steps {
                sh "./gradlew coverageCheck -PcoverageMinimum=${COVERAGE_MINIMUM} --no-daemon"
            }
        }

        stage('SonarQube') {
            when { expression { env.ENABLE_SONAR == 'true' } }
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        if command -v sonar-scanner >/dev/null 2>&1; then
                          sonar-scanner -Dproject.settings=sonar-project.properties \
                            -Dsonar.branch.name="${BRANCH_NAME:-develop}"
                        else
                          echo "Skipping Sonar — scanner not installed"
                        fi
                    '''
                }
            }
        }

        stage('Derive Image Metadata') {
            steps {
                script {
                    if (!env.AWS_REGION?.trim()) {
                        error('Set AWS_REGION for ECR operations.')
                    }

                    def branchName = env.BRANCH_NAME?.trim()
                    if (!branchName) {
                        branchName = sh(returnStdout: true, script: 'git rev-parse --abbrev-ref HEAD').trim()
                    }

                    def registry = env.ECR_REGISTRY?.trim()
                    if (!registry) {
                        if (!env.AWS_ACCOUNT_ID?.trim()) {
                            error('Set AWS_ACCOUNT_ID or ECR_REGISTRY for ECR image publishing.')
                        }
                        registry = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
                    }

                    env.REF_TAG = branchName.toLowerCase().replaceAll('[^a-z0-9._-]', '-')
                    env.GIT_COMMIT_SHA = sh(returnStdout: true, script: 'git rev-parse HEAD').trim()
                    env.GIT_SHA_SHORT = env.GIT_COMMIT_SHA.take(12)
                    // Primary deploy tag = full Git commit SHA (matches GitHub Actions ECR tag)
                    env.IMAGE_TAG = env.GIT_COMMIT_SHA
                    env.IMAGE_TAG_SHORT = "sha-${env.GIT_SHA_SHORT}"
                    env.ECR_REGISTRY = registry
                    env.ECR_INGESTION_REPOSITORY = 'enterprise-rag-ingestion-service'
                    env.ECR_QUERY_REPOSITORY = 'enterprise-rag-query-service'
                    env.INGESTION_IMAGE = "${registry}/${env.ECR_INGESTION_REPOSITORY}:${env.IMAGE_TAG}"
                    env.QUERY_IMAGE = "${registry}/${env.ECR_QUERY_REPOSITORY}:${env.IMAGE_TAG}"
                    env.INGESTION_IMAGE_SHORT = "${registry}/${env.ECR_INGESTION_REPOSITORY}:${env.IMAGE_TAG_SHORT}"
                    env.QUERY_IMAGE_SHORT = "${registry}/${env.ECR_QUERY_REPOSITORY}:${env.IMAGE_TAG_SHORT}"
                    env.INGESTION_IMAGE_BRANCH = "${registry}/${env.ECR_INGESTION_REPOSITORY}:${env.REF_TAG}"
                    env.QUERY_IMAGE_BRANCH = "${registry}/${env.ECR_QUERY_REPOSITORY}:${env.REF_TAG}"
                    env.INGESTION_IMAGE_LATEST = "${registry}/${env.ECR_INGESTION_REPOSITORY}:latest"
                    env.QUERY_IMAGE_LATEST = "${registry}/${env.ECR_QUERY_REPOSITORY}:latest"
                }
            }
        }

        stage('Ensure ECR Repositories') {
            steps {
                sh './scripts/create-ecr-repos.sh'
            }
        }

        stage('Docker Build & Tag') {
            steps {
                sh '''
                    docker build --platform linux/amd64 -f ingestion-service/Dockerfile -t "${INGESTION_IMAGE}" .
                    docker build --platform linux/amd64 -f query-service/Dockerfile -t "${QUERY_IMAGE}" .
                    docker tag "${INGESTION_IMAGE}" "${INGESTION_IMAGE_SHORT}"
                    docker tag "${QUERY_IMAGE}" "${QUERY_IMAGE_SHORT}"
                    docker tag "${INGESTION_IMAGE}" "${INGESTION_IMAGE_BRANCH}"
                    docker tag "${QUERY_IMAGE}" "${QUERY_IMAGE_BRANCH}"
                    if [ "${REF_TAG}" = "main" ] || [ "${REF_TAG}" = "master" ]; then
                      docker tag "${INGESTION_IMAGE}" "${INGESTION_IMAGE_LATEST}"
                      docker tag "${QUERY_IMAGE}" "${QUERY_IMAGE_LATEST}"
                    fi
                '''
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                    aws ecr get-login-password --region "${AWS_REGION}" \
                      | docker login --username AWS --password-stdin "${ECR_REGISTRY}"
                    docker push "${INGESTION_IMAGE}"
                    docker push "${QUERY_IMAGE}"
                    docker push "${INGESTION_IMAGE_SHORT}"
                    docker push "${QUERY_IMAGE_SHORT}"
                    docker push "${INGESTION_IMAGE_BRANCH}"
                    docker push "${QUERY_IMAGE_BRANCH}"
                    if [ "${REF_TAG}" = "main" ] || [ "${REF_TAG}" = "master" ]; then
                      docker push "${INGESTION_IMAGE_LATEST}"
                      docker push "${QUERY_IMAGE_LATEST}"
                    fi
                    echo "Deployed tag (Git commit SHA): ${IMAGE_TAG}"
                '''
            }
        }

        stage('Deploy to EC2 (Staging)') {
            when {
                expression {
                    env.ENABLE_DEPLOY == 'true' &&
                    env.DEPLOY_TARGET == 'ec2' &&
                    env.STAGING_SSH_HOST?.trim()
                }
            }
            steps {
                withCredentials([
                    sshUserPrivateKey(credentialsId: 'staging-ssh-key', keyFileVariable: 'SSH_KEY')
                ]) {
                    sh '''
                        export SSH_KEY_PATH="${SSH_KEY}"
                        export DOCKER_REGISTRY="${ECR_REGISTRY}"
                        export AWS_REGION="${AWS_REGION}"
                        export INGESTION_IMAGE="${INGESTION_IMAGE}"
                        export QUERY_IMAGE="${QUERY_IMAGE}"
                        export OLLAMA_IMAGE="${OLLAMA_IMAGE}"
                        ./scripts/deploy-ec2-compose.sh
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes (Dev)') {
            when {
                expression {
                    env.ENABLE_DEPLOY == 'true' && env.DEPLOY_TARGET == 'k8s'
                }
            }
            steps {
                sh '''
                    kubectl version --client || true
                    if [ -f k8s/overlays/dev/kustomization.yaml ]; then
                      kubectl apply -k "${K8S_OVERLAY}"
                      kubectl rollout status deployment/ingestion-service -n "${K8S_NAMESPACE}" --timeout=300s || true
                      kubectl rollout status deployment/query-service -n "${K8S_NAMESPACE}" --timeout=300s || true
                      kubectl rollout status deployment/prometheus -n "${K8S_NAMESPACE}" --timeout=120s || true
                      kubectl rollout status deployment/grafana -n "${K8S_NAMESPACE}" --timeout=120s || true
                    fi
                '''
            }
        }
    }

    post {
        success { echo "Dev pipeline OK — target ${DEPLOY_TARGET}" }
        failure { echo 'Dev pipeline failed.' }
        always { cleanWs(deleteDirs: true) }
    }
}
